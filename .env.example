# OKX API Configuration
OKX_API_KEY=your_okx_api_key
OKX_SECRET=your_okx_secret
OKX_PASSPHRASE=your_okx_passphrase
OKX_API_REGION=global
OKX_BASE_URL=https://www.okx.com
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/public

# OKX account mode
# live  -> real account
# demo  -> OKX demo trading account
# paper -> alias for demo trading, sends x-simulated-trading: 1
OKX_ACCOUNT_MODE=demo

# Redis
REDIS_URL=redis://redis:6379

# PostgreSQL
DATABASE_URL=postgresql://trading:change-me-postgres-password@postgres:5432/trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=trading
PGCONNECT_TIMEOUT=10

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-root-password
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=trading-app
MINIO_SECRET_KEY=change-me-minio-app-password
MINIO_BUCKET_TELEMETRY=telemetry
MINIO_BUCKET_BACKUPS=backups
MINIO_BUCKET_MARKET_DATA=market-data

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=ai-trading-swarm

# Grafana / Jaeger
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-password
JAEGER_UI_PORT=16686

# Application URLs
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# Autonomous swarm execution
MAX_POSITION_USD=100
MIN_CONFIDENCE_THRESHOLD=60
AUTO_EXECUTE_ENABLED=true
MAX_BALANCE_USAGE_PCT=0.9
MIN_TRADE_NOTIONAL=5
AUTONOMOUS_TRADING_ENABLED=false
AUTONOMOUS_SYMBOL_SELECTION=auto
AUTONOMOUS_SYMBOL=BTC-USDT
AUTONOMOUS_SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,XRP-USDT,ADA-USDT,DOGE-USDT,LINK-USDT
AUTONOMOUS_QUOTE_CURRENCIES=USDT,EUR,USDC
AUTONOMOUS_SYMBOL_LIMIT=8
AUTONOMOUS_QUOTE_CURRENCY=USDT
AUTONOMOUS_TIMEFRAME=1H
AUTONOMOUS_INTERVAL_MS=60000
AUTONOMOUS_COOLDOWN_MS=120000
LIVE_TRADING_BUDGET_USD=10
AUTONOMY_MAX_SYMBOL_ALLOCATION_PCT=0.4
MAX_SYMBOL_ALLOCATION_PCT=0.4
MAX_DAILY_TRADES=20
MIN_DIRECTIONAL_EDGE_SCORE=0.12
MIN_MARKET_QUALITY_SCORE=0.55
MIN_NET_EDGE_BPS=6
MIN_REWARD_RISK=1.35
EXPECTED_FEE_BPS=8
AUTONOMY_DEGRADED_SNAPSHOT_SUPPRESSION_THRESHOLD=10
AUTONOMY_DEGRADED_SNAPSHOT_SUPPRESSION_WINDOW_MS=1800000

# Position monitoring
POSITION_MONITOR_ENABLED=true
POSITION_MONITOR_INTERVAL_MS=15000

# Trailing stop
TRAILING_STOP_ENABLED=true
TRAILING_STOP_DISTANCE_PCT=1.5

CRON_SECRET=replace-with-a-long-random-secret

# Production market-data controls
ALLOW_SYNTHETIC_MARKET_FALLBACK=true
REQUIRE_REALTIME_MARKET_DATA=false
MARKET_TICKER_STALE_MS=15000
MARKET_ORDERBOOK_STALE_MS=15000
MARKET_REST_REFRESH_MS=10000
MARKET_CANDLE_REFRESH_MS=30000
OKX_ACCOUNT_CACHE_TTL_MS=5000
OKX_ACCOUNT_STALE_FALLBACK_MS=120000
SWARM_DIAGNOSTIC_VOTE_TIMEOUT_MS=8000
